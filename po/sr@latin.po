msgstr "RAID-1 niz"

#: udisks/udisksobjectinfo.c:356
msgctxt "mdraid-desc"
msgid "RAID-4 Array"
msgstr "RAID-4 niz"

#: udisks/udisksobjectinfo.c:358
msgctxt "mdraid-desc"
msgid "RAID-5 Array"
msgstr "RAID-5 niz"

#: udisks/udisksobjectinfo.c:360
msgctxt "mdraid-desc"
msgid "RAID-6 Array"
msgstr "RAID-6 niz"

#: udisks/udisksobjectinfo.c:362
msgctxt "mdraid-desc"
